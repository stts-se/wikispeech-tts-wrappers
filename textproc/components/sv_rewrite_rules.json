{
    "rules":
    [
	{
	    "rule_type": "utterance",
	    "input": "\\b([1-9][0-9]+)-(tal(?:et)?s?)\\b",
	    "output": "\\1|||year|||nbsp \\2",
	    "tests": [
		{
		    "from": "90-talet",
		    "to": "nittiotalet"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.]+) *– *([0-9.]+)\\b",
	    "output": "\\1 till \\2",
	    "tests": [
		{
		    "from": "3+2",
		    "to": "3 till 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.]+) *\\+ *([0-9.]+)\\b",
	    "output": "\\1 plus \\2",
	    "tests": [
		{
		    "from": "3+2",
		    "to": "3 plus 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.]+) *- *([0-9.]+)\\b",
	    "output": "\\1 minus \\2",
	    "tests": [
		{
		    "from": "3+2",
		    "to": "3 minus 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.]+) *[*x\u00D7] *([0-9.]+)\\b",
	    "output": "\\1 gånger \\2",
	    "tests": [
		{
		    "from": "3*2",
		    "to": "3 gånger 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.]+) *\u00F7 *([0-9.]+)\\b",
	    "output": "\\1 dividerat med \\2",
	    "tests": [
		{
		    "from": "3*2",
		    "to": "3 dividerat med 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bt[. ]*ex(\\.|\\b)",
	    "output": "till exempel",
	    "tests": [
		{
		    "from": "Man kan t.ex. baka med havremjöl istället",
		    "to": "Man kan till exempel baka med havremjöl istället"
		},
		{
		    "from": "Miljön t.ex.",
		    "to": "Miljön till exempel"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bbl[. ]*a(\\.|\\b)",
	    "output": "bland annat",
	    "test": [
		{
		    "from": "TODO",
		    "to": "TODO"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bkr(\\.|\\b)",
	    "output": "kronor",
	    "test": [
		{
		    "from": "10 kr",
		    "to": "10 kronor"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bm[. ]*fl(\\.|\\b)",
	    "output": "med flera",
	    "test": [
		{
		    "from": "TODO",
		    "to": "TODO"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([kK]arl|[gG]ustav|[eE]rik) ([0-9]+|[XIV]+)(\\.|\\b)",
	    "output": "\\1 den \\2|||ordinal",
	    "test": [
		{
		    "from": "Gustav VI Adolf",
		    "to": "Gustav den 6|||ordinal Adolf"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9]{1,2}[.]?) (januari|februari|mars|april|maj|juni|juli|augusti|september|oktober|november|december)\\b",
	    "output": "\\1|||ordinal \\2",
	    "test": [
		{
		    "from": "3 februari",
		    "to": "3|||ordinal februari"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^(1[1-9][0-9]{2})$",
	    "output": "\\1|||year",
	    "test": [
		{
		    "from": "Året var 1994",
		    "to": "Året var 1994|||year"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([0-9]+):(a|e)$",
	    "output": "\\1|||ordinal",
	    "test": [
		{
		    "from": "Han kom på 2:a plats",
		    "to": "Han kom på 2|||ordinal plats"
		}
	    ]
	}
    ],
    "tests": [
	{
	    "from": "Karl XII, t.ex., kom på 2:a plats den 3 maj 1984, och vann 10 kr",
	    "to": "Karl den tolfte, till exempel, kom på andra plats den tredje maj nitton hundra åttiofyra, och vann tio kronor"
	}
    ]
}
