{
    "rbnf_lang": "sv",
    "sentence_split_re": "([.?!]) +([A-Z0-9]+)",
    "token_split_re": "[\\s]+",
    "punctuation_re": "[(),;.¿?¡!-\"”“':]+",
    "rbnf_compound_delimiter": "-",
    "fail_on_error": true,
    "rules":
    [
	{
	    "rule_type": "file",
	    "file": "sv_time.json"
	},
	{
	    "rule_type": "file",
	    "file": "sv_numerals.json"
	},
	{
	    "rule_type": "file",
	    "file": "sv_abbrevs.json"
	},
	{
	    "rule_type": "file",
	    "file": "sv_units.json"
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bB[. ]*P(\\.|\\b)",
	    "output": "före nutid",
	    "tests": [
		{
		    "from": "2000 BP",
		    "to": "2000 före nutid"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bf[. ]*kr(\\.|\\b)",
	    "output": "före Kristus",
	    "tests": [
		{
		    "from": "2000 F.Kr",
		    "to": "2000 före Kristus"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\be[. ]*kr(\\.|\\b)",
	    "output": "efter Kristus",
	    "tests": [
		{
		    "from": "2000 e.Kr",
		    "to": "2000 efter Kristus"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b(del) ([XIV]+)\\b",
	    "output": "\\1 \\2|||roman",
	    "tests": [
		{
		    "from": "del I",
		    "to": "del I|||roman"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	  "input": "\\b([0-9]+)[ \u00A0]+([0-9]{3})\\b",
	    "output": "\\1\\2",
	    "tests": [
		{
		    "from": "1 000",
		    "to": "1000"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bS/S\\b",
	    "output": "SS|||spellout",
	    "tests": [
		{
		    "from": "S/S Norrskär",
		    "to": "SS|||spellout Norrskär"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9][0-9]+)-(tal(?:et)?s?)\\b",
	    "output": "\\1|||year|||nodelim \\2",
	    "tests": [
		{
		    "from": "90-talet",
		    "to": "90|||year|||nodelim talet"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "description": "intervals with en dash (U2013)",
	    "input": "\\b([0-9.,]+) *\u2013 *([0-9.,]+)\\b",
	    "output": "\\1 till \\2",
	    "tests": [
		{
		    "from": "3\u20132",
		    "to": "3 till 2"
		},
		{
		    "from": "3–2",
		    "to": "3 till 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *\\+ *([0-9.,]+)\\b",
	    "output": "\\1 plus \\2",
	    "tests": [
		{
		    "from": "3+2",
		    "to": "3 plus 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *\\+",
	    "output": "\\1 plus",
	    "tests": [
		{
		    "from": "3+ ord",
		    "to": "3 plus ord"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *[-\u2212] *([0-9.,]+)\\b",
	    "output": "\\1 minus \\2",
	    "tests": [
		{
		    "from": "3−2",
		    "to": "3 minus 2"
		},
		{
		    "from": "3\u22122",
		    "to": "3 minus 2"
		},
		{
		    "from": "3-2",
		    "to": "3 minus 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *− *([0-9.,]+)\\b",
	    "output": "\\1 till \\2",
	    "tests": [
		{
		    "from": "3−2",
		    "to": "3 till 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *[*x\u00D7] *([0-9.,]+)\\b",
	    "output": "\\1 gånger \\2",
	    "tests": [
		{
		    "from": "3*2",
		    "to": "3 gånger 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *\u00F7 *([0-9.,]+)\\b",
	    "output": "\\1 dividerat med \\2",
	    "tests": [
		{
		    "from": "3\u00F72",
		    "to": "3 dividerat med 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b(Karl|Gusta[vf]|Johan|Erik|Harald|Håkon|Viktoria|Victoria|Elisabeth|Elizabeth|Sigismund|Fredrik|Oscar) +([0-9]+|[XIV]+)(\\.|\\b)",
	    "ignore_case": true,
	    "output": "\\1 den \\2|||ordinal",
	    "tests": [
		{
		    "from": "Gustav VI Adolf",
		    "to": "Gustav den VI|||ordinal Adolf"
		},
		{
		    "from": "Det var karl XII, som dog.",
		    "to": "Det var karl den XII|||ordinal, som dog."
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9]{1,2}[.]?) +(januari|februari|mars|april|maj|juni|juli|augusti|september|oktober|november|december)\\b",
	    "output": "\\1|||ordinal \\2",
	    "tests": [
		{
		    "from": "3 februari",
		    "to": "3|||ordinal februari"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([12][1-9][0-9]{2})$",
	    "output": "\\1|||year",
	    "tests": [
		{
		    "from": "Året var 1994",
		    "to": "Året var 1994|||year"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([0-9]+):(a|e)$",
	    "output": "\\1|||ordinal",
	    "tests": [
		{
		    "from": "Han kom på 2:a plats",
		    "to": "Han kom på 2|||ordinal plats"
		},
		{
		    "from": "Han var den 3:e, av alla, som kom i mål",
		    "to": "Han var den 3|||ordinal, av alla, som kom i mål"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([0-9]+):([0-9]+)$",
	    "output": "\\1 kolon \\2",
	    "tests": [
		{
		    "from": "Skalan är 1:2",
		    "to": "Skalan är 1 kolon 2"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([a-z0-9]+)[.]([a-z0-9]+)@([a-z0-9]+)[.](se)$",
	    "output": "\\1 punkt \\2 snabel-a \\3 punkt \\4|||spellout",
	    "tests": [
		{
		    "from": "gurra.g@regeringen.se",
		    "to": "gurra punkt g snabel-a regeringen punkt se|||spellout"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([a-z0-9]+)[.]([a-z0-9]+)@([a-z0-9]+)[.]([a-z0-9]+)$",
	    "output": "\\1 punkt \\2 snabel-a \\3 punkt \\4",
	    "tests": [
		{
		    "from": "gurra.g@regeringen.org",
		    "to": "gurra punkt g snabel-a regeringen punkt org"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "\\b([\\w]+)-([0-9.,]+)\\b",
	    "output": "\\1 \\2",
	    "tests": [
		{
		    "from": "cesium-135",
		    "to": "cesium 135"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "\\b([0-9.,]+)-([\\w]+)\\b",
	    "output": "\\1 \\2",
	    "tests": [
		{
		    "from": "48-bitars",
		    "to": "48 bitars"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "description": "fallback rule to separate numbers from letters",
	    "input": "([0-9,.]+)([A-Z]+)",
	    "ignore_case": true,
	    "output": "\\1 \\2",
	    "tests": [
		{
		    "from": "100G",
		    "to": "100 G"
		}
	    ]
	}
    ],
    "tests": [
	{
	    "from": "Karl XII, t.ex., kom på 2:a plats den 3 maj 1984, och vann 10 kr",
	    "to": "Karl den tolfte, till exempel, kom på andra plats den tredje maj nitton-hundra-åttio-fyra, och vann tio kronor"
	},
	{
	    "from": "Den 3 februari såg jag en häst",
	    "to": "Den tredje februari såg jag en häst"
	},
	{
	    "from": "Den 3   februari såg jag en häst",
	    "to": "Den tredje februari såg jag en häst"
	},
	{
	    "from": "Han kom på 2:a plats",
	    "to": "Han kom på andra plats"
	},
	{
	    "from": "Han var den 3:e, av alla, som kom i mål",
	    "to": "Han var den tredje, av alla, som kom i mål"
	},
	{
	    "from": "Det var Karl XII, som dog",
	    "to": "Det var Karl den tolfte, som dog"
	},
	{
	    "from": "del I",
	    "to": "del ett"
	},
	{
	    "from": "cesium-137",
	    "to": "cesium ett-hundra-trettio-sju"
	},
	{
	    "from": "48-bitars",
	    "to": "fyrtio-åtta bitars"
	},
	{
	    "from": "10:45",
	    "to": "tio fyrtio-fem"
	},
	{
	    "from": "09:45",
	    "to": "noll nio fyrtio-fem"
	},
	{
	    "from": "År 1200 e.Kr",
	    "to": "År tolv-hundra efter Kristus"
	},
	{
	    "from": "Det hände år 2025",
	    "to": "Det hände år två-tusen tjugo-fem"
	},
	{
	    "from": "Det hände år 2025 och 26",
	    "to": "Det hände år två-tusen tjugo-fem och tjugo-sex"
	},
	{
	    "from": "Det hände år 2025 26",
	    "to": "Det hände år två-tusen tjugo-fem tjugo-sex"
	}

    ]
}
