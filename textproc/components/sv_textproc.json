{
    "rbnf_lang": "sv",
    "sentence_split_re": "([.?!]) +([A-Z0-9]+)",
    "token_split_re": "[\\s]+",
    "punctuation_re": "[(),;.¿?¡!-]+",
    "fail_on_error": true,
    "rules":
    [
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9]+)[ \u00A0]+([0-9]+)\\b",
	    "output": "\\1\\2",
	    "tests": [
		{
		    "from": "1 000",
		    "to": "tusen"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bS/S\\b",
	    "output": "SS|||spell",
	    "tests": [
		{
		    "from": "S/S Norrskär",
		    "to": "SS Norrskär"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([1-9][0-9]+)-(tal(?:et)?s?)\\b",
	    "output": "\\1|||year|||nodelim \\2",
	    "tests": [
		{
		    "from": "90-talet",
		    "to": "nittiotalet"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *– *([0-9.,]+)\\b",
	    "output": "\\1 till \\2",
	    "tests": [
		{
		    "from": "3+2",
		    "to": "3 till 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *\\+ *([0-9.,]+)\\b",
	    "output": "\\1 plus \\2",
	    "tests": [
		{
		    "from": "3+2",
		    "to": "3 plus 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *- *([0-9.,]+)\\b",
	    "output": "\\1 minus \\2",
	    "tests": [
		{
		    "from": "3-2",
		    "to": "3 minus 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *[*x\u00D7] *([0-9.,]+)\\b",
	    "output": "\\1 gånger \\2",
	    "tests": [
		{
		    "from": "3*2",
		    "to": "3 gånger 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9.,]+) *\u00F7 *([0-9.,]+)\\b",
	    "output": "\\1 dividerat med \\2",
	    "tests": [
		{
		    "from": "3*2",
		    "to": "3 dividerat med 2"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bt[. ]*ex(\\.|\\b)",
	    "output": "till exempel",
	    "tests": [
		{
		    "from": "Man kan t.ex. baka med havremjöl istället",
		    "to": "Man kan till exempel baka med havremjöl istället"
		},
		{
		    "from": "Miljön t.ex.",
		    "to": "Miljön till exempel"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bbl[. ]*a(\\.|\\b)",
	    "output": "bland annat",
	    "test": [
		{
		    "from": "Det var bl.a. hans fel",
		    "to": "Det var bland annat hans fel"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bdvs(\\.|\\b)",
	    "output": "det vill säga",
	    "test": [
		{
		    "from": "Hon sa, dvs., inget",
		    "to": "Hon sa, det vill säga, inget"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bo[. ]*s[. ]*v(\\.|\\b)",
	    "output": "och så vidare",
	    "test": [
		{
		    "from": "Det var bad, bad, bad, osv., i all oändlighet.",
		    "to": "Det var bad, bad, bad, och så vidare, i all oändlighet."
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bkr(\\.|\\b)",
	    "output": "kronor",
	    "test": [
		{
		    "from": "10 kr",
		    "to": "10 kronor"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bm[. ]*fl(\\.|\\b)",
	    "output": "med flera",
	    "test": [
		{
		    "from": "Arresten på Bohus med Rolf Cederlöf, Gunilla Söderström, Loa Falkman m.fl",
		    "to": "Arresten på Bohus med Rolf Cederlöf, Gunilla Söderström, Loa Falkman med flera"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\bm[. ]+m(\\.|\\b)",
	    "output": "med mera",
	    "test": [
		{
		    "from": "Våtmark, sankmark och sumpmark m. m. är enligt den svenska våtmarksinventeringens definition sådan mark.",
		    "to": "Våtmark, sankmark och sumpmark med mera är enligt den svenska våtmarksinventeringens definition sådan mark."
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "(\\b|[0-9]+)mm(\\.|\\b)",
	    "output": "\\1 millimeter",
	    "test": [
		{
		    "from": "Bordsskivan var 17mm lång",
		    "to": "Bordsskivan var 17 millimeter lång"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b(Karl|Gusta[vf]|Johan|Erik|Harald|Håkon|Viktoria|Victoria|Elisabeth|Elizabeth|Sigismund|Fredrik|Oscar) +([0-9]+|[XIV]+)(\\.|\\b)",
	    "ignore_case": true,
	    "output": "\\1 den \\2|||ordinal",
	    "test": [
		{
		    "from": "Gustav VI Adolf",
		    "to": "Gustav den VI|||ordinal Adolf"
		},
		{
		    "from": "Det var karl XII, som dog.",
		    "to": "Det var karl den XII|||ordinal, som dog."
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "\\b([0-9]{1,2}[.]?) +(januari|februari|mars|april|maj|juni|juli|augusti|september|oktober|november|december)\\b",
	    "output": "\\1|||ordinal \\2",
	    "test": [
		{
		    "from": "3 februari",
		    "to": "3|||ordinal februari"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^(1[1-9][0-9]{2})$",
	    "output": "\\1|||year",
	    "test": [
		{
		    "from": "Året var 1994",
		    "to": "Året var 1994|||year"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([0-9]+):(a|e)$",
	    "output": "\\1|||ordinal",
	    "test": [
		{
		    "from": "Han kom på 2:a plats",
		    "to": "Han kom på 2|||ordinal plats"
		},
		{
		    "from": "Han var den 3:e, av alla, som kom i mål",
		    "to": "Han var den 3|||ordinal, av alla, som kom i mål"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([0-9]+):([0-9]+)$",
	    "output": "\\1 kolon \\2",
	    "test": [
		{
		    "from": "Skalan är 1:2",
		    "to": "Skalan är 1 kolon 2"
		}
	    ]
	},
	{
	    "rule_type": "token",
	    "input": "^([a-z0-9]+)[.]([a-z0-9]+)@([a-z0-9]+)[.]([a-z0-9]+)",
	    "output": "\\1 punkt \\2 snabel-a \\3 punkt \\4",
	    "test": [
		{
		    "from": "gurra.g@regeringen.se",
		    "to": "gurra punkt g snabel-a regeringen punkt se"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "-([0-9.,]+) *°",
	    "output": "minus \\1 grader",
	    "tests": [
		{
		    "from": "-12.5 °",
		    "to": "minus tolv komma fem grader"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "-([0-9.,]+) *° *C\\b",
	    "output": "minus \\1 grader Celcius",
	    "tests": [
		{
		    "from": "-12.5°C",
		    "to": "minus tolv komma fem grader Celsius"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "([0-9.,]+) *° *C\\b",
	    "output": "\\1 grader Celcius",
	    "tests": [
		{
		    "from": "12.5°C",
		    "to": "tolv komma fem grader Celsius"
		}
	    ]
	},
	{
	    "rule_type": "utterance",
	    "input": "([0-9.,]+) *°",
	    "output": "\\1 grader",
	    "tests": [
		{
		    "from": "12.5 °",
		    "to": "tolv komma fem grader"
		}
	    ]
	}
    ],
    "tests": [
	{
	    "from": "Karl XII, t.ex., kom på 2:a plats den 3 maj 1984, och vann 10 kr",
	    "to": "Karl den tolfte, till exempel, kom på andra plats den tredje maj nittonhundraåttiofyra, och vann tio kronor"
	},
	{
	    "from": "Den 3 februari såg jag en häst",
	    "to": "Den tredje februari såg jag en häst"
	},
	{
	    "from": "Den 3   februari såg jag en häst",
	    "to": "Den tredje februari såg jag en häst"
	},
	{
	    "from": "Han kom på 2:a plats",
	    "to": "Han kom på andra plats"
	},
	{
	    "from": "Han var den 3:e, av alla, som kom i mål",
	    "to": "Han var den tredje, av alla, som kom i mål"
	},
	{
	    "from": "Det var Karl XII, som dog",
	    "to": "Det var Karl den tolfte, som dog"
	}
    ]
}
